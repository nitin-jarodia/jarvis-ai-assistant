# Environment Variables for Jarvis AI Assistant
# Copy this file to .env and fill in your values

# Authentication
# Generate a long random value and keep it private
# SECRET_KEY=replace_with_a_long_random_secret_key

# Groq API configuration
# GROQ_API_KEY=your_groq_api_key_here
# GROQ_TIMEOUT_SECONDS=45

# Multimodal routing
# IMAGE_PROVIDER_NAME=pollinations
# IMAGE_API_KEY=
# IMAGE_PROVIDER_MODEL=flux
# IMAGE_PROVIDER_BASE_URL=https://api.openai.com/v1
#
# VISION_PROVIDER_NAME=huggingface
# VISION_API_KEY=
# VISION_PROVIDER_MODEL=Qwen/Qwen2.5-VL-7B-Instruct
# VISION_PROVIDER_BASE_URL=https://router.huggingface.co/v1

# App settings (optional overrides)
# APP_HOST=127.0.0.1
# APP_PORT=8000
# DEBUG=true
